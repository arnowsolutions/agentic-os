# ── Agentic OS ── Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and ignored.

# ── Server ──────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=INFO

# ── Vapi.ai ──────────────────────────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_ASSISTANT_ID=9b00342e-1951-4bd0-b4a5-5ca4c9827bd0
VAPI_ENDPOINT_PATH=/vapi

# ── Supabase ─────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_PROJECT_ID=

# ── Google OAuth ─────────────────────────────────────────────────────────────────
GOOGLE_TOKEN_PATH=data/google_token.json

# ── Security ─────────────────────────────────────────────────────────────────────
WEBHOOK_IP_ALLOWLIST=
WEBHOOK_SECRET=
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300

# ── Central Auth (SSO IdP) ───────────────────────────────────────────────────────
SESSION_SECRET=           # Required — generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_TTL_HOURS=8

# ── LLM ──────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── Notifications ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=
SCHEDULE_EMAIL_RECIPIENT=
