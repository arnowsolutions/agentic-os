# Agentic OS — environment template
# Copy to .env and fill in real values. Do not commit .env.

# Server
HOST=0.0.0.0
PORT=8090
LOG_LEVEL=INFO

# Vapi
VAPI_API_KEY=
VAPI_ASSISTANT_ID=9b00342e-1951-4bd0-b4a5-5ca4c9827bd0
VAPI_ENDPOINT_PATH=/vapi

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_PROJECT_ID=

# Google OAuth token path
GOOGLE_TOKEN_PATH=data/google_token.json

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
# Comma-separated list of trusted upstream IPs (e.g., Vapi egress IPs)
WEBHOOK_IP_ALLOWLIST=
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300

# Cache
CACHE_TTL_SECONDS=60

# Logging / data
LOG_DIR=logs
CRM_PATH=data/crm_contacts.json
PIN_DB_PATH=data/user_pins.json
KNOWLEDGE_DIR=knowledge-base

# LLM fallback
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
